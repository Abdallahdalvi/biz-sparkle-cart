# Self-hosted Supabase (dalvi.cloud)
VITE_SUPABASE_URL=https://supabase.dalvi.cloud
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# Server-only (used by createServerFn handlers)
SUPABASE_URL=https://supabase.dalvi.cloud
SUPABASE_PUBLISHABLE_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Razorpay (server-only — keys never ship to browser; key_id is returned by createRazorpayOrder)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Shiprocket
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
# Optional — defaults to "Primary" (must exist in your Shiprocket dashboard)
SHIPROCKET_PICKUP_LOCATION=Primary